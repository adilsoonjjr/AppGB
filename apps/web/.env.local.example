# Firebase Client SDK
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Firebase Admin SDK (para uso server-side)
FIREBASE_ADMIN_PROJECT_ID=your_project_id
FIREBASE_ADMIN_CLIENT_EMAIL=your_service_account_email
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Configurações do Restaurante
NEXT_PUBLIC_RESTAURANT_NAME="Meu Restaurante"
NEXT_PUBLIC_RESTAURANT_PHONE="5511999999999"
NEXT_PUBLIC_PRIMARY_COLOR="#ef4444"

# WhatsApp (Twilio ou similar)
WHATSAPP_API_URL=https://api.twilio.com/...
WHATSAPP_TOKEN=your_token
WHATSAPP_PHONE_NUMBER=5511999999999

# PIX
NEXT_PUBLIC_PIX_KEY=your_pix_key
NEXT_PUBLIC_PIX_NAME="Meu Restaurante"
NEXT_PUBLIC_PIX_CITY="São Paulo"

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Funções auxiliares ---
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? getUserData().role : null;
    }

    function getUserRestaurantId() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? getUserData().restaurantId : null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && getUserRole() == 'superadmin';
    }

    function isAdminOf(restaurantId) {
      return isAuthenticated() && (
        getUserRole() == 'superadmin' ||
        (getUserRole() == 'admin' && getUserRestaurantId() == restaurantId)
      );
    }

    function isStaffOf(restaurantId) {
      return isAuthenticated() && (
        getUserRole() == 'superadmin' ||
        ((getUserRole() == 'admin' || getUserRole() == 'employee') &&
          getUserRestaurantId() == restaurantId)
      );
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // --- Restaurants ---
    match /restaurants/{restaurantId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAdminOf(restaurantId) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // --- Users (perfis) ---
    match /users/{uid} {
      allow read: if isOwner(uid) || isSuperAdmin();
      allow create: if isAuthenticated() && request.auth.uid == uid;
      allow update: if isOwner(uid) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // --- Categories ---
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if
        isAdminOf(request.resource.data.restaurantId) ||
        isAdminOf(resource.data.restaurantId);
    }

    // --- Products ---
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdminOf(request.resource.data.restaurantId);
      allow update: if isAdminOf(resource.data.restaurantId);
      allow delete: if isAdminOf(resource.data.restaurantId);
    }

    // --- Counters (sequência de número de pedido por restaurante) ---
    // Apenas escrita autenticada; leitura restrita ao staff (auditoria)
    match /counters/{counterId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() || !isAuthenticated(); // transações do checkout (client SDK)
    }

    // --- Coupons ---
    match /coupons/{couponId} {
      // Leitura pública permitida SOMENTE para validação no checkout (qualquer um pode consultar
      // um cupom pelo código — necessário para guest orders). Listagem geral exige ser staff.
      allow read: if true;

      // Apenas admin do restaurante cria, desativa ou exclui cupons
      allow create: if isAdminOf(request.resource.data.restaurantId);
      allow update: if isAdminOf(resource.data.restaurantId) ||
        // Checkout pode apenas incrementar usedCount — nenhum outro campo pode ser alterado
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usedCount', 'updatedAt']);
      allow delete: if isAdminOf(resource.data.restaurantId);
    }

    // --- Orders ---
    match /orders/{orderId} {
      // Qualquer um pode criar pedido (clientes sem login incluídos)
      allow create: if true;

      // Leitura:
      // - Staff do restaurante lê pedidos do seu restaurante
      // - Cliente logado lê o próprio pedido
      // - Guest (sem login) acessa pelo ID direto — ID aleatório do Firestore é suficientemente opaco;
      //   só aceita se o pedido não tiver customerUid (pedido anônimo)
      allow read: if isStaffOf(resource.data.restaurantId) ||
        (isAuthenticated() && request.auth.uid == resource.data.customerUid) ||
        (!isAuthenticated() && resource.data.customerUid == null);

      // Atualização:
      // - Staff atualiza status e qualquer campo
      // - Cliente logado pode: alterar notas, rating, e CANCELAR (status → 'cancelled')
      //   somente se o pedido ainda estiver 'pending'
      allow update: if isStaffOf(resource.data.restaurantId) ||
        (isAuthenticated() &&
          request.auth.uid == resource.data.customerUid &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['notes', 'rating', 'status', 'updatedAt']) &&
          // Só pode mudar status para 'cancelled' e apenas quando ainda 'pending'
          (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status']) ||
            (request.resource.data.status == 'cancelled' && resource.data.status == 'pending')
          )
        );

      allow delete: if isAdminOf(resource.data.restaurantId);
    }

    // --- Expenses ---
    match /expenses/{expenseId} {
      allow read: if isAdminOf(resource.data.restaurantId);
      allow create: if isAdminOf(request.resource.data.restaurantId);
      allow update, delete: if isAdminOf(resource.data.restaurantId);
    }

    // --- Favorites ---
    match /favorites/{favoriteId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.uid;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.uid;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.uid;
    }
  }
}
